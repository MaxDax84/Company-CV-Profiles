# Gmail SMTP configuration (for the contact form)
#
# Setup instructions:
# 1. Go to your Google Account > Security
# 2. Enable 2-Step Verification (required)
# 3. Search for "App Passwords" and create one for "Mail"
# 4. Paste the 16-character password below (no spaces)
#
# Then rename this file to .env.local

GMAIL_USER=massimo.dassano@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
